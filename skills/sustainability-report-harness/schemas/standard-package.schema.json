{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sustainability-report-harness/standard-package.schema.json",
  "title": "Reviewed Standard Package",
  "type": "object",
  "required": ["package_status", "standard_version", "clauses", "requirements"],
  "properties": {
    "fixture_notice": {"type": "string"},
    "package_status": {"enum": ["simulated", "reviewed", "published"]},
    "reviewed_by": {"type": "string", "minLength": 1},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "standard_version": {"type": "object"},
    "clauses": {"type": "array", "minItems": 1},
    "requirements": {"type": "array", "minItems": 1}
  },
  "additionalProperties": false
}
