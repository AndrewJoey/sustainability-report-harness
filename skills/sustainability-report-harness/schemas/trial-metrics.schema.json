{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sustainability-report-harness/trial-metrics.schema.json",
  "title": "MVP trial metrics record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trial_id",
    "recorded_at",
    "recorded_by",
    "scope",
    "baseline_minutes",
    "agent_runtime_minutes",
    "human_review_minutes",
    "repeat_parse_count",
    "repeat_write_count",
    "mapping_correction_count",
    "evidence_location_error_count",
    "content_total",
    "content_kept",
    "content_modified",
    "content_rewritten",
    "selected_requirements_total",
    "selected_requirements_covered",
    "cross_agent_reprocessed_files",
    "notes"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "trial_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"},
    "recorded_at": {"type": "string", "minLength": 1},
    "recorded_by": {"type": "string", "minLength": 1},
    "scope": {"type": "string", "minLength": 1},
    "baseline_minutes": {"type": "number", "minimum": 0},
    "agent_runtime_minutes": {"type": "number", "minimum": 0},
    "human_review_minutes": {"type": "number", "minimum": 0},
    "repeat_parse_count": {"type": "integer", "minimum": 0},
    "repeat_write_count": {"type": "integer", "minimum": 0},
    "mapping_correction_count": {"type": "integer", "minimum": 0},
    "evidence_location_error_count": {"type": "integer", "minimum": 0},
    "content_total": {"type": "integer", "minimum": 0},
    "content_kept": {"type": "integer", "minimum": 0},
    "content_modified": {"type": "integer", "minimum": 0},
    "content_rewritten": {"type": "integer", "minimum": 0},
    "selected_requirements_total": {"type": "integer", "minimum": 0},
    "selected_requirements_covered": {"type": "integer", "minimum": 0},
    "cross_agent_reprocessed_files": {"type": "integer", "minimum": 0},
    "notes": {"type": ["string", "null"]}
  }
}
