{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Formal sustainability report outline",
  "type": "object",
  "required": ["schema_version", "generated_at", "target_length_words", "source_ledger_hash", "anchor_section_id", "sections", "conflicts"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "generated_at": {"type": "string"},
    "target_length_words": {"type": "integer", "minimum": 1},
    "source_ledger_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "anchor_section_id": {"type": "string", "minLength": 1},
    "sections": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "conflicts": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": false
}
